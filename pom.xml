<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.4.1</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>

	<groupId>es.hugoalvarezajenjo</groupId>
	<artifactId>selecta</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>SelecTA</name>
	<description>Web aplication for helping students choose their subject</description>
	<url>https://github.com/HugoAlvarezAjenjo/SelecTA</url>

	<licenses>
		<license/>
	</licenses>

	<developers>
		<developer>
			<name>Hugo Alvarez Ajenjo</name>
			<url>https://github.com/HugoAlvarezAjenjo</url>
		</developer>
	</developers>

	<properties>
		<java.version>21</java.version>
	</properties>
	<dependencies>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-thymeleaf</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-devtools</artifactId>
			<scope>runtime</scope>
			<optional>true</optional>
		</dependency>
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>runtime</scope>
		</dependency>
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
			<scope>runtime</scope>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.springframework.security</groupId>
			<artifactId>spring-security-test</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-security</artifactId>
		</dependency>
		<dependency>
			<groupId>org.thymeleaf.extras</groupId>
			<artifactId>thymeleaf-extras-springsecurity6</artifactId>
		</dependency>
		<dependency>
			<groupId>org.projectlombok</groupId>
			<artifactId>lombok</artifactId>
			<scope>provided</scope>
		</dependency>
		<dependency>
			<groupId>org.springdoc</groupId>
			<artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
			<version>2.8.4</version>
		</dependency>
		<dependency>
			<groupId>org.commonmark</groupId>
			<artifactId>commonmark</artifactId>
			<version>0.27.1</version>
		</dependency>
		<dependency>
			<groupId>org.commonmark</groupId>
			<artifactId>commonmark-ext-gfm-tables</artifactId>
			<version>0.27.1</version>
		</dependency>

	</dependencies>

	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<configuration>
					<annotationProcessorPaths>
					<path>
						<groupId>org.projectlombok</groupId>
						<artifactId>lombok</artifactId>
						<version>1.18.38</version>
					</path>
					</annotationProcessorPaths>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
			</plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.3</version>
                <configuration>
                    <argLine>
                        ${argLine}
                        -Djdk.instrument.traceUsage
                        -XX:+EnableDynamicAgentLoading
                    </argLine>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.13</version>
                <configuration>
                    <excludes>
                        <!-- Exclude UI/controller layer (thin routing, no business logic) -->
                        <exclude>**/ui/**</exclude>
                        <!-- Exclude REST controllers (thin delegation to services) -->
                        <exclude>**/controllers/**</exclude>
                        <!-- Exclude Spring config classes -->
                        <exclude>**/config/**</exclude>
                        <!-- Exclude application entry point -->
                        <exclude>**/SelecTaApplication.class</exclude>
                        <!-- Exclude JPA entities (POJOs with no logic, only getters/setters) -->
                        <exclude>**/services/subjects/Subject.class</exclude>
                        <exclude>**/services/subjects/SubjectRating.class</exclude>
                        <exclude>**/services/subjects/SubjectRecommendationCriteria.class</exclude>
                        <exclude>**/services/user/User.class</exclude>
                        <exclude>**/services/user/Student.class</exclude>
                        <exclude>**/services/user/Teacher.class</exclude>
                        <exclude>**/services/user/Admin.class</exclude>
                        <exclude>**/services/user/UserRole.class</exclude>
                        <exclude>**/services/resources/SubjectResource.class</exclude>
                        <exclude>**/services/resources/ResourceFolder.class</exclude>
                        <exclude>**/services/resources/ResourceVote.class</exclude>
                        <exclude>**/services/resources/ResourceTag.class</exclude>
                        <exclude>**/services/resources/ResourceType.class</exclude>
                        <exclude>**/services/resources/VoteType.class</exclude>
                        <exclude>**/services/enrollment/EnrollmentListItem.class</exclude>
                        <exclude>**/services/contributions/ContributionRequest.class</exclude>
                        <exclude>**/services/contributions/RequestStatus.class</exclude>
                        <exclude>**/services/contributions/RequestType.class</exclude>
                        <exclude>**/services/recommendation/SubjectScoreDTO.class</exclude>
                        <exclude>**/services/recommendation/RecommendationWeights.class</exclude>
                        <exclude>**/services/recommendation/UserContext.class</exclude>
                        <!-- Exclude JPA Specifications (query configuration, not business logic) -->
                        <exclude>**/services/subjects/repository/SubjectSpecifications.class</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-report-plugin</artifactId>
                <version>3.5.3</version>
                <executions>
                    <execution>
                        <phase>test</phase>
                        <goals>
                            <goal>report-only</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
		</plugins>
	</build>

</project>
